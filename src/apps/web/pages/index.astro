---
import BaseLayout from '../layouts/BaseLayout.astro';
import { LitSmokeCounter } from '../components/lit-smoke-counter';
---

<BaseLayout title="Lego Train Layout Planner">
  <main>
    <h1>Lego Train Layout Planner</h1>
    <p>Enter your track inventory to start planning layouts.</p>
    <LitSmokeCounter client:load />
    <p>
      <a href={`${import.meta.env.BASE_URL}onboarding/`}>Set up inventory</a>
      ·
      <a href={`${import.meta.env.BASE_URL}editor/`}>Open editor</a>
    </p>
  </main>
</BaseLayout>
